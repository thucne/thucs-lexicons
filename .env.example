# Server-only -- required for AI search routes.
# Routes return 503 "AI search is not configured." when this is unset.
OPENAI_API_KEY=

# Server-only -- caps live OpenAI fallback calls per runtime instance per UTC day.
# Set to 0 as an emergency brake. Cached/local fallback responses do not count.
OPENAI_DAILY_REQUEST_LIMIT=100

# Server-only -- caches successful AI fallback responses by query to reduce quota burn.
# Set to 0 to disable in-memory AI response caching.
OPENAI_CACHE_TTL_SECONDS=86400

# Public site URL (no trailing slash) -- used for absolute API URLs in SWR
NEXT_PUBLIC_DOMAIN=http://localhost:3000
